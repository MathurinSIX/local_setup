# Copy to .env and adjust: cp .env.example .env
# Docker Compose loads .env from this directory automatically.

# --- Traefik (Host() rules for routed services) ---
# Suffix for hostnames that resolve to this machine (often *.localhost → 127.0.0.1).
# With the defaults below you use:
#   MinIO S3:   http://minio.<TRAEFIK_DOMAIN>/     (e.g. http://minio.localhost/)
#   MinIO UI:   http://minio-console.<TRAEFIK_DOMAIN>/   (e.g. http://minio-console.localhost/)
TRAEFIK_DOMAIN=localhost

# --- PostgreSQL (postgres service) ---
# One container = one PostgreSQL server. You can (and should) give each app its own
# *database* on that server: connect as superuser and run CREATE DATABASE myapp;
# (or use your migration tool). This is separate from POSTGRES_DB below.
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
# The superuser and first database are created only when the postgres_data volume is empty.
# If you later change POSTGRES_USER/POSTGRES_DB here, the old roles/DBs remain: remove the
# volume (data loss) or adjust users/DBs inside Postgres to match.
# Name of the *first* database created when the data volume is new. Not mandatory
# to "be" your app: it is only a bootstrap default. If you omit POSTGRES_DB in
# .env, docker-compose still sets a default; the official image would otherwise
# create a database named the same as POSTGRES_USER.
POSTGRES_DB=public
# Host port published to PostgreSQL (localhost:POSTGRES_PORT from the machine; postgres:5432 from sibling containers on traefik-public).
POSTGRES_PORT=5432

# --- MinIO (S3-compatible API + console) ---
# MinIO requires MINIO_ROOT_USER length ≥ 3 and MINIO_ROOT_PASSWORD length ≥ 8 (shorter values make the container exit on start).
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminadmin
